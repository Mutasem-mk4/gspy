# Maintainer: Mutasem Kharma <mutasem@gspy.dev>
# SPDX-License-Identifier: GPL-2.0-only
pkgname=gspy
pkgver=0.2.0
pkgrel=1
pkgdesc="Forensic goroutine-to-syscall inspector for live Go processes using eBPF."
arch=('x86_64')
url="https://github.com/Mutasem-mk4/gspy"
license=('GPL2')
groups=('blackarch' 'blackarch-forensic')
depends=('glibc')
makedepends=('go>=1.21' 'clang>=14' 'llvm>=14' 'libbpf' 'bpf')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('a9202eac2dce840d37c65a198bfb0f4d90cd4a06e8aefa543dbf6759c842bb72')

prepare() {
    cd "$pkgname-$pkgver"
    export GOPATH="$srcdir/go"
    export PATH="$GOPATH/bin:$PATH"
    go install github.com/cilium/ebpf/cmd/bpf2go@v0.17.1
}

build() {
    cd "$pkgname-$pkgver"
    export CGO_ENABLED=0
    export GOPATH="$srcdir/go"
    export PATH="$GOPATH/bin:$PATH"
    export GOFLAGS="-mod=mod"

    make generate
    make build-only VERSION=$pkgver
}

check() {
    cd "$pkgname-$pkgver"
    go test -v -tags=testing ./...
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 bin/gspy "$pkgdir/usr/bin/gspy"
    install -Dm644 man/gspy.1 "$pkgdir/usr/share/man/man1/gspy.1"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
